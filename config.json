        "speed_min": 0,
        "speed_max": 200,
        "coolant_temp_normal": 95,
        "fault_injection": {
            "enabled": false,
            "dtc_list": [],
            "probability": 0.0
        }
    },
    "api": {
        "rest": {
            "enabled": true,
            "host": "0.0.0.0",
            "port": 8080,
            "cors_enabled": true
        },
        "websocket": {
            "enabled": true,
            "host": "0.0.0.0",
            "port": 8081,
            "update_interval_ms": 100
        },
        "grpc": {
            "enabled": false,
            "host": "0.0.0.0",
            "port": 50051
        }
    },
    "logging": {
        "level": "info",
        "levels": ["trace", "debug", "info", "warning", "error", "critical"],
        "file": "/var/log/ecu_emulator.log",
        "max_size_mb": 100,
        "max_files": 5,
        "console_output": true,
        "can_traffic_log": "/var/log/can_traffic.log"
    },
    "metrics": {
        "enabled": true,
        "prometheus_port": 8082
    },
    "database": {
        "path": "/etc/ecu_emulator/emulator.db",
        "auto_migrate": true
    },
    "security": {
        "seed_key_enabled": true,
        "max_attempts": 5,
        "lockout_time_seconds": 60,
        "session_timeout_seconds": 5,
        "security_timeout_seconds": 10
    },
    "diagnostics": {
        "default_dtcs": [
            {"code": "P0101", "description": "Mass Air Flow Circuit Range/Performance", "severity": "major"},
            {"code": "P0300", "description": "Random/Multiple Cylinder Misfire Detected", "severity": "major"},
            {"code": "P0420", "description": "Catalyst System Efficiency Below Threshold", "severity": "moderate"},
            {"code": "P0442", "description": "Evaporative Emission System Leak Detected", "severity": "minor"},
            {"code": "P0500", "description": "Vehicle Speed Sensor Malfunction", "severity": "major"}
        ]
    }
